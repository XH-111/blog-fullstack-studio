generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  displayName  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSetting {
  id              String   @id @default("site")
  siteTitle       String
  heroTitle       String
  heroDescription String
  heroImage       String?
  welcomeEyebrow  String   @default("欢迎光临")
  welcomeTitle    String   @default("一套可以长期写作、持续扩展、适合沉淀技术与生活的个人博客")
  welcomeBody     String   @default("这里会持续更新 Java、JVM、后端工程实践、项目复盘和个人成长记录。它不是只展示结果的站点，而是一份长期可读的个人工程档案。")
  welcomeTags     String   @default("简洁首页,后台写作,分类管理,Markdown 编辑,AI 正确性评论,JVM 专栏")
  featuredTitle   String   @default("置顶文章")
  featuredDescription String @default("从知识库里挑选的最多三篇内容。")
  profileName     String
  profileTagline  String
  profileImage    String?
  updatedAt       DateTime @updatedAt
}

model HomeReaction {
  id        String   @id @default("home")
  total     Int      @default(0)
  tagCounts String   @default("{}")
  updatedAt DateTime @updatedAt
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model Tag {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  postTags  PostTag[]
}

model Post {
  id                Int                 @id @default(autoincrement())
  title             String
  slug              String              @unique
  excerpt           String
  coverImage        String?
  contentMarkdown   String
  contentJson       String?
  contentHtml       String
  contentText       String?
  status            PostStatus          @default(DRAFT)
  isFeatured        Boolean             @default(false)
  publishedAt       DateTime?
  viewCount         Int                 @default(0)
  categoryId        Int
  category          Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  postTags          PostTag[]
  comments          Comment[]
  aiReview          AiReview?
  aiOfficialComment AiOfficialComment?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model PostTag {
  postId Int
  tagId  Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model Comment {
  id         Int      @id @default(autoincrement())
  postId     Int
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorName String
  email      String?
  content    String
  floor      Int
  isAi       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model GuestbookMessage {
  id           Int      @id @default(autoincrement())
  authorName   String
  content      String
  isPrivate    Boolean  @default(false)
  replyContent String?
  repliedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AiReview {
  id                 Int      @id @default(autoincrement())
  postId             Int      @unique
  post               Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  typoIssues         String
  clarityIssues      String
  logicIssues        String
  knowledgeIssues    String
  formatIssues       String
  overallSuggestion  String
  rawResponse        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AiOfficialComment {
  id        Int      @id @default(autoincrement())
  postId    Int      @unique
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PostStatus {
  DRAFT
  PUBLISHED
}
